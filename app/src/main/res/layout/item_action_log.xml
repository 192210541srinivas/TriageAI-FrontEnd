<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#E5E7EB"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#F5F3FF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/ivActionIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_history"
                app:tint="#7C3AED" />

            <TextView
                android:id="@+id/tvActionType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="MEDICATION ADMINISTERED"
                android:textColor="#7C3AED"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvActionTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="14:30"
                android:textColor="#6B7280"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvActionNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Administered 500mg Paracetamol as requested by Dr. Smith."
            android:textColor="#111827"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvDoctorInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="By Doctor #101"
            android:textColor="#6B7280"
            android:textSize="11sp"
            android:textStyle="italic" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

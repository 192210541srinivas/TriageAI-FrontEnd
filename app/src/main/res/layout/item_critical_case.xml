<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Priority Accent Strip -->
        <View
            android:id="@+id/viewPriorityAccent"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@color/critical_main"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvPatientId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_id_badge"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="P003"
            android:textColor="@color/critical_main"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/viewPriorityAccent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTimeAgo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="15 min waiting"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/tvPatientId"
            app:layout_constraintStart_toEndOf="@id/tvPatientId"
            app:layout_constraintTop_toTopOf="@id/tvPatientId" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/critical_main"
            app:cardCornerRadius="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:id="@+id/tvPriorityLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="CRITICAL"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvPatientName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Emma Thompson"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/tvRiskScoreLabel"
            app:layout_constraintStart_toStartOf="@id/tvPatientId"
            app:layout_constraintTop_toBottomOf="@id/tvPatientId" />

        <TextView
            android:id="@+id/tvPatientAge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="34 years old"
            android:textColor="#6B7280"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/tvPatientName"
            app:layout_constraintTop_toBottomOf="@id/tvPatientName" />

        <TextView
            android:id="@+id/tvRiskScoreLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Risk:"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvPatientName" />

        <TextView
            android:id="@+id/tvRiskScoreValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="72%"
            android:textColor="#111827"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvRiskScoreLabel" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCondition"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/critical_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvPatientName"
            app:layout_constraintTop_toBottomOf="@id/tvPatientAge">
            <TextView
                android:id="@+id/tvCondition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="High fever with chills"
                android:textColor="#111827"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Vitals Grid -->
        <LinearLayout
            android:id="@+id/layoutVitals"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvPatientName"
            app:layout_constraintTop_toBottomOf="@id/cardCondition">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_vital_item"
                android:orientation="vertical"
                android:padding="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BP"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/tvBp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="130/85"
                    android:textColor="#111827"
                    android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="8dp" android:layout_height="0dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_vital_item"
                android:orientation="vertical"
                android:padding="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HR"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/tvHr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="105"
                    android:textColor="#111827"
                    android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="8dp" android:layout_height="0dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_vital_item"
                android:orientation="vertical"
                android:padding="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SpO2"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/tvSpo2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="95%"
                    android:textColor="#111827"
                    android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="8dp" android:layout_height="0dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_vital_item"
                android:orientation="vertical"
                android:padding="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Temp"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/tvTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="39.2°C"
                    android:textColor="#111827"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Medical History -->
        <TextView
            android:id="@+id/tvMedicalHistory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="History: None"
            android:textColor="#6B7280"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvPatientName"
            app:layout_constraintTop_toBottomOf="@id/layoutVitals" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewDetails"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/critical_main"
            android:text="View Details"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvPatientName"
            app:layout_constraintTop_toBottomOf="@id/tvMedicalHistory" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>

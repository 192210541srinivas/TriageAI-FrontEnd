<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".TriageStep2Activity">

    <!-- Blue Header Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blue_primary"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvTitle"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Vital Signs"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 5-segment Progress Bar -->
        <LinearLayout
            android:id="@+id/layoutProgress"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvTitle">

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_progress_active" />

            <View
                android:layout_width="8dp"
                android:layout_height="match_parent" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_progress_active" />

            <View
                android:layout_width="8dp"
                android:layout_height="match_parent" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_progress_inactive" />

            <View
                android:layout_width="8dp"
                android:layout_height="match_parent" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_progress_inactive" />

            <View
                android:layout_width="8dp"
                android:layout_height="match_parent" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_progress_inactive" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvStepInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Step 2 of 5 • Vital Signs"
            android:textColor="@color/white"
            android:alpha="0.8"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/layoutProgress"
            app:layout_constraintTop_toBottomOf="@id/layoutProgress" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Form Section -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/btnContinue"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Blood Pressure -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blood Pressure (mmHg) *"
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_pulse_red" />

                    <EditText
                        android:id="@+id/etSystolic"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Systolic"
                        android:inputType="number"
                        android:paddingStart="12dp"
                        android:textSize="16sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:text="/"
                    android:textColor="#9CA3AF"
                    android:textSize="18sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1.2"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <EditText
                        android:id="@+id/etDiastolic"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Diastolic"
                        android:inputType="number"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Heart Rate -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Heart Rate (bpm) *"
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_heart_red" />

                <EditText
                    android:id="@+id/etHeartRate"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Enter heart rate"
                    android:inputType="number"
                    android:paddingStart="12dp"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Body Temperature -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Body Temperature (°C) *"
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_temp_orange" />

                <EditText
                    android:id="@+id/etTemperature"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Enter temperature"
                    android:inputType="numberDecimal"
                    android:paddingStart="12dp"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- SpO2 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Oxygen Saturation (SpO2 %) *"
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_spo2_blue" />

                <EditText
                    android:id="@+id/etSpo2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Enter SpO2"
                    android:inputType="number"
                    android:paddingStart="12dp"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Respiratory Rate -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Respiratory Rate (breaths/min) *"
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_respiratory_blue" />

                <EditText
                    android:id="@+id/etRespiratoryRate"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Enter respiratory rate"
                    android:inputType="number"
                    android:paddingStart="12dp"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- AVPU (Consciousness Level) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="AVPU (Consciousness Level) *"
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleGroupAvpu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAlert"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Alert"
                    android:textAllCaps="false"
                    android:textColor="#166534"
                    android:textSize="16sp"
                    app:backgroundTint="#F0FDF4"
                    app:cornerRadius="12dp"
                    app:strokeColor="#22C55E" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerbal"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Verbal"
                    android:textAllCaps="false"
                    android:textColor="#854D0E"
                    android:textSize="16sp"
                    app:backgroundTint="#FEFCE8"
                    app:cornerRadius="12dp"
                    app:strokeColor="#EAB308" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPainful"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Painful"
                    android:textAllCaps="false"
                    android:textColor="#9A3412"
                    android:textSize="16sp"
                    app:backgroundTint="#FFF7ED"
                    app:cornerRadius="12dp"
                    app:strokeColor="#F97316" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUnconscious"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Unconscious"
                    android:textAllCaps="false"
                    android:textColor="#991B1B"
                    android:textSize="16sp"
                    app:backgroundTint="#FEF2F2"
                    app:cornerRadius="12dp"
                    app:strokeColor="#EF4444" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Normal Ranges Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_normal_ranges"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Normal Ranges:"
                    android:textColor="@color/blue_primary"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="• BP: 90/60 - 120/80 mmHg"
                    android:textColor="@color/blue_primary"
                    android:textSize="13sp"
                    android:alpha="0.8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="• HR: 60-100 bpm"
                    android:textColor="@color/blue_primary"
                    android:textSize="13sp"
                    android:alpha="0.8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="• Temp: 36.5-37.5°C"
                    android:textColor="@color/blue_primary"
                    android:textSize="13sp"
                    android:alpha="0.8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="• SpO2: 95-100%"
                    android:textColor="@color/blue_primary"
                    android:textSize="13sp"
                    android:alpha="0.8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="• RR: 12-20 breaths/min"
                    android:textColor="@color/blue_primary"
                    android:textSize="13sp"
                    android:alpha="0.8" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_margin="24dp"
        android:enabled="false"
        android:text="Continue to Symptoms"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="32dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#E9D5FF"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <View
            android:id="@+id/ivDoctorAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_check_circle"
            android:backgroundTint="#F3E8FF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_person"
            app:layout_constraintBottom_toBottomOf="@id/ivDoctorAvatar"
            app:layout_constraintEnd_toEndOf="@id/ivDoctorAvatar"
            app:layout_constraintStart_toStartOf="@id/ivDoctorAvatar"
            app:layout_constraintTop_toTopOf="@id/ivDoctorAvatar"
            app:tint="#9333EA" />

        <TextView
            android:id="@+id/tvDoctorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Dr. Jennifer Williams"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/ivDoctorAvatar"
            app:layout_constraintTop_toTopOf="@id/ivDoctorAvatar" />

        <TextView
            android:id="@+id/tvSpecialty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cardiology"
            android:textColor="#6B7280"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/tvDoctorName"
            app:layout_constraintTop_toBottomOf="@id/tvDoctorName" />

        <ProgressBar
            android:id="@+id/pbWorkload"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_marginTop="12dp"
            android:progress="60"
            android:progressDrawable="@drawable/bg_ai_progress_bar"
            android:progressTint="#9333EA"
            app:layout_constraintEnd_toStartOf="@id/tvWorkloadRatio"
            app:layout_constraintStart_toStartOf="@id/ivDoctorAvatar"
            app:layout_constraintTop_toBottomOf="@id/tvSpecialty" />

        <TextView
            android:id="@+id/tvWorkloadRatio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="3/5"
            android:textColor="#6B7280"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/pbWorkload"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/pbWorkload" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/pbWorkload">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAccept"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:backgroundTint="#10B981"
                android:text="Accept"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_completed_check"
                app:iconGravity="textStart" />

            <View
                android:layout_width="12dp"
                android:layout_height="match_parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:backgroundTint="#F3F4F6"
                android:text="Reject"
                android:textAllCaps="false"
                android:textColor="#374151"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_close"
                app:iconGravity="textStart"
                app:iconTint="#374151" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>

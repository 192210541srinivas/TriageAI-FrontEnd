<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardNotification"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="28dp"
    app:cardElevation="20dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_notification_gradient"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Top Status Badge & Close -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_critical_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="URGENT ASSIGNMENT"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Just Now"
                android:textColor="#9CA3AF"
                android:textSize="11sp" />
        </RelativeLayout>

        <!-- Patient Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_person"
                android:padding="12dp"
                app:shapeAppearanceOverlay="@style/CircleImage"
                android:background="#F3F4F6"
                app:tint="#4B5563" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPatientName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Robert Sterling"
                    android:textColor="#111827"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:id="@+id/tvPatientMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="54Y • Male • Critical"
                    android:textColor="#6B7280"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="20dp"
            android:background="#E5E7EB" />

        <!-- Vitals Horizontal Scroller or Grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3">

            <!-- BP -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_pulse_blue" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BP" android:textColor="#9CA3AF" android:textSize="10sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvBP" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="145/95" android:textColor="#111827" android:textSize="15sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- HR -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_pulse_blue" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HR" android:textColor="#9CA3AF" android:textSize="10sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvHR" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="105" android:textColor="#111827" android:textSize="15sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- SpO2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_spo2_blue" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SPO2" android:textColor="#9CA3AF" android:textSize="10sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvSpO2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="92%" android:textColor="#DC2626" android:textSize="15sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Temp -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_temp_orange" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TEMP" android:textColor="#9CA3AF" android:textSize="10sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvTemp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="38.2°C" android:textColor="#111827" android:textSize="15sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- RR -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_respiratory_blue" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RR" android:textColor="#9CA3AF" android:textSize="10sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvRR" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="22" android:textColor="#111827" android:textSize="15sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </GridLayout>

        <!-- Complaint Preview Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#EEF2FF"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="#F9FAFB">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHIEF COMPLAINT"
                    android:textColor="#1E40AF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tvComplaint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Severe chest pressure radiating to left arm, acute shortness of breath since 15 mins."
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Admin Message -->
        <TextView
            android:id="@+id/tvAdminMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Admin Message here..."
            android:textColor="#1F2937"
            android:textSize="14sp"
            android:textStyle="italic"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="DECHINE"
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAccept"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:layout_weight="2.5"
                android:backgroundTint="#2563EB"
                android:text="ACCEPT CASE"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                app:cornerRadius="18dp"
                app:icon="@drawable/ic_tick"
                app:iconGravity="textStart"
                app:iconTint="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:fitsSystemWindows="true">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:fontFamily="sans-serif-black"
        android:text="Settings"
        android:textColor="#111827"
        android:textSize="28sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavCard"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- ACCOUNT SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="ACCOUNT"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <!-- User Profile -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutUserProfile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <ImageView
                            android:id="@+id/ivProfile"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_nav_item_selected"
                            android:padding="8dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#0D62FF" />
                        <TextView
                            android:id="@+id/tvProfileTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="User Profile"
                            android:textColor="#111827"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@id/ivProfile"
                            app:layout_constraintTop_toTopOf="@id/ivProfile" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View and edit your information"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            app:layout_constraintStart_toStartOf="@id/tvProfileTitle"
                            app:layout_constraintTop_toBottomOf="@id/tvProfileTitle" />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#9CA3AF" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginHorizontal="16dp"/>
                    <!-- Change Password -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutChangePassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <ImageView
                            android:id="@+id/ivLock"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="#F5F3FF"
                            android:padding="3dp"
                            android:src="@drawable/ic_lock"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                        <TextView
                            android:id="@+id/tvLockTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Change Password"
                            android:textColor="#111827"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@id/ivLock"
                            app:layout_constraintTop_toTopOf="@id/ivLock" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Update your security credentials"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            app:layout_constraintStart_toStartOf="@id/tvLockTitle"
                            app:layout_constraintTop_toBottomOf="@id/tvLockTitle" />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#9CA3AF" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PRIVACY SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="PRIVACY &amp; SECURITY"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <!-- Data Privacy -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutPrivacy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <ImageView
                            android:id="@+id/ivShield"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="#ECFDF5"
                            android:padding="3dp"
                            android:src="@drawable/ic_stable"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            />
                        <TextView
                            android:id="@+id/tvShieldTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Data Privacy &amp; Security"
                            android:textColor="#111827"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@id/ivShield"
                            app:layout_constraintTop_toTopOf="@id/ivShield" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HIPAA compliance information"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            app:layout_constraintStart_toStartOf="@id/tvShieldTitle"
                            app:layout_constraintTop_toBottomOf="@id/tvShieldTitle" />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#9CA3AF" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginHorizontal="16dp"/>
                    <!-- AI Transparency -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutAiTransparency"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <ImageView
                            android:id="@+id/ivDoc"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="#EFF6FF"
                            android:padding="8dp"
                            android:src="@drawable/ic_dashboard"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#3B82F6" />
                        <TextView
                            android:id="@+id/tvDocTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="AI Transparency &amp; Bias"
                            android:textColor="#111827"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@id/ivDoc"
                            app:layout_constraintTop_toTopOf="@id/ivDoc" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="How our AI makes decisions"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            app:layout_constraintStart_toStartOf="@id/tvDocTitle"
                            app:layout_constraintTop_toBottomOf="@id/tvDocTitle" />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#9CA3AF" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- LEGAL SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="LEGAL"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <!-- System Disclaimer -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutDisclaimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <ImageView
                            android:id="@+id/ivWarning"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="#FFFBEB"
                            android:padding="0dp"
                            android:src="@drawable/ic_doc"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            />
                        <TextView
                            android:id="@+id/tvWarningTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="System Disclaimer"
                            android:textColor="#111827"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@id/ivWarning"
                            app:layout_constraintTop_toTopOf="@id/ivWarning" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Important legal information"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            app:layout_constraintStart_toStartOf="@id/tvWarningTitle"
                            app:layout_constraintTop_toBottomOf="@id/tvWarningTitle" />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#9CA3AF" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginHorizontal="16dp"/>
                    <!-- Terms of Service -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutTerms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <ImageView
                            android:id="@+id/ivTerms"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="#F9FAFB"
                            android:padding="8dp"
                            android:src="@drawable/ic_dashboard"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#6B7280" />
                        <TextView
                            android:id="@+id/tvTermsTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Terms of Service"
                            android:textColor="#111827"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@id/ivTerms"
                            app:layout_constraintTop_toTopOf="@id/ivTerms" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Review usage terms"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            app:layout_constraintStart_toStartOf="@id/tvTermsTitle"
                            app:layout_constraintTop_toBottomOf="@id/tvTermsTitle" />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#9CA3AF" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ABOUT SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="ABOUT"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutAppInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:id="@+id/ivInfo"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="#EFF6FF"
                        android:padding="0dp"
                        android:src="@drawable/img_4"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                         />
                    <TextView
                        android:id="@+id/tvInfoTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="App Info &amp; Version"
                        android:textColor="#111827"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/ivInfo"
                        app:layout_constraintTop_toTopOf="@id/ivInfo" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="v1.0.0 • Healthcare Edition"
                        android:textColor="#6B7280"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/tvInfoTitle"
                        app:layout_constraintTop_toBottomOf="@id/tvInfoTitle" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#9CA3AF" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CONTACT SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="CONTACT US"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutContactUs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:id="@+id/ivChat"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="#F9FAFB"
                        android:padding="8dp"
                        android:src="@drawable/ic_chat_bubble"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#6B7280" />
                    <TextView
                        android:id="@+id/tvChatTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Contact Us"
                        android:textColor="#111827"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/ivChat"
                        app:layout_constraintTop_toTopOf="@id/ivChat" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Get in touch with support"
                        android:textColor="#6B7280"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/tvChatTitle"
                        app:layout_constraintTop_toBottomOf="@id/tvChatTitle" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#9CA3AF" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignOut"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="Sign Out"
                android:textAllCaps="false"
                android:textColor="#EF4444"
                app:backgroundTint="#FEF2F2"
                app:cornerRadius="12dp"
                app:strokeColor="#FEE2E2"
                app:strokeWidth="1dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Paramedic Bottom Navigation Bar Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@color/white"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <LinearLayout
                android:id="@+id/navDashboard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_dashboard"
                    app:tint="#9CA3AF" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Dashboard"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navPatients"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_patients"
                    app:tint="#9CA3AF" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Patients"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navSettings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="8dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_settings"
                        app:tint="#0D62FF" />
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Settings"
                    android:textColor="#0D62FF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>

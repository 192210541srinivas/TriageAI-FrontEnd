<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    tools:context=".CaseReportActivity">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E02424"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Case Report"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBack" />

        <TextView
            android:id="@+id/tvPatientNameHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="T089 • John Martinez"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvHeaderTitle" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/btnExportReport"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Case Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Case Summary"
                        android:textColor="#111827"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <View android:layout_width="match_parent" android:layout_height="12dp" />

                    <!-- Grid for Summary (simplified with LinearLayers) -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">

                        <!-- Date & Time Row -->
                        <TextView
                            android:id="@+id/lblDateTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Date &amp; Time:"
                            android:textColor="#6B7280"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvDateTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jan 22, 2026\n14:25"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textAlignment="viewEnd"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <!-- Patient Row -->
                        <TextView
                            android:id="@+id/lblPatient"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Patient:"
                            android:textColor="#6B7280"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvDateTime" />

                        <TextView
                            android:id="@+id/tvPatientNameSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="John Martinez"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toBottomOf="@id/lblPatient"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/lblPatient" />

                        <!-- Priority Row -->
                        <TextView
                            android:id="@+id/lblPriority"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Priority:"
                            android:textColor="#6B7280"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvPatientNameSummary" />

                        <TextView
                            android:id="@+id/tvPriority"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CRITICAL"
                            android:textColor="#EF4444"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="@id/lblPriority"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/lblPriority" />

                        <!-- AI Risk Score Row -->
                        <TextView
                            android:id="@+id/lblRiskScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="AI Risk Score:"
                            android:textColor="#6B7280"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvPriority" />

                        <TextView
                            android:id="@+id/tvRiskScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="95%"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="@id/lblRiskScore"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/lblRiskScore" />

                        <!-- Outcome Row -->
                        <TextView
                            android:id="@+id/lblOutcome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Outcome:"
                            android:textColor="#6B7280"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvRiskScore" />

                        <TextView
                            android:id="@+id/tvOutcome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Admitted"
                            android:textColor="#10B981"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toBottomOf="@id/lblOutcome"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/lblOutcome" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AI Analysis Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FEF2F2"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_brain" app:tint="#EF4444" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="AI Analysis" android:textColor="#111827" android:textSize="18sp" android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="16dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chief Complaint:" android:textColor="#111827" android:textStyle="bold" />
                    <TextView android:id="@+id/tvChiefComplaint" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Chest pain with shortness of breath" android:textColor="#4B5563" />

                    <View android:layout_width="match_parent" android:layout_height="12dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Key Symptoms:" android:textColor="#111827" android:textStyle="bold" />
                    <TextView android:id="@+id/tvKeySymptoms" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Severe chest pain, difficulty breathing, sweating" android:textColor="#4B5563" />

                    <View android:layout_width="match_parent" android:layout_height="12dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Risk Factors:" android:textColor="#111827" android:textStyle="bold" />
                    <TextView android:id="@+id/tvRiskFactors" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Hypertension, diabetes, elevated vitals" android:textColor="#4B5563" />

                    <View android:layout_width="match_parent" android:layout_height="12dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI Recommendation:" android:textColor="#111827" android:textStyle="bold" />
                    <TextView android:id="@+id/tvAiRecommendation" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Immediate cardiac evaluation" android:textColor="#4B5563" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Vital Signs Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_pulse_blue" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Vital Signs" android:textColor="#111827" android:textSize="18sp" android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="16dp" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2">

                        <!-- BP -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_vital_item"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BP" android:textColor="#6B7280" android:textSize="12sp" />
                            <TextView android:id="@+id/tvBp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="180/110 mmHg" android:textColor="#111827" android:textSize="16sp" android:textStyle="bold" />
                        </LinearLayout>

                        <!-- HR -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:background="@drawable/bg_vital_item"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HR" android:textColor="#6B7280" android:textSize="12sp" />
                            <TextView android:id="@+id/tvHr" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="125 bpm" android:textColor="#111827" android:textSize="16sp" android:textStyle="bold" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="12dp" />

                        <!-- SpO2 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_vital_item"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SpO2" android:textColor="#6B7280" android:textSize="12sp" />
                            <TextView android:id="@+id/tvSpo2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="89%" android:textColor="#111827" android:textSize="16sp" android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Temp -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:background="@drawable/bg_vital_item"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Temp" android:textColor="#6B7280" android:textSize="12sp" />
                            <TextView android:id="@+id/tvTemp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="37.2°C" android:textColor="#111827" android:textSize="16sp" android:textStyle="bold" />
                        </LinearLayout>

                    </GridLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Treatment Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_history" app:tint="#7C3AED" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Treatment Summary" android:textColor="#111827" android:textSize="18sp" android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="16dp" />

                    <TextView
                        android:id="@+id/tvTreatmentSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Patient was immediately assessed and stabilized. ECG performed showing signs of acute cardiac event. Cardiac enzymes elevated. Patient admitted to cardiac care unit for further monitoring and treatment. Responded well to initial interventions."
                        android:textColor="#4B5563"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky Footer Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExportReport"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_margin="16dp"
        android:backgroundTint="#2563EB"
        android:text="Export Full Report"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

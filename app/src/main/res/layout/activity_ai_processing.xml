<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_ai_gradient"
    tools:context=".AIProcessingActivity">

    <!-- Glow Effect -->
    <View
        android:id="@+id/viewGlow"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_ai_glow"
        app:layout_constraintCircle="@id/cardIcon"
        app:layout_constraintCircleRadius="0dp"
        app:layout_constraintCircleAngle="0"
        app:layout_constraintBottom_toBottomOf="@id/cardIcon"
        app:layout_constraintEnd_toEndOf="@id/cardIcon"
        app:layout_constraintStart_toStartOf="@id/cardIcon"
        app:layout_constraintTop_toTopOf="@id/cardIcon" />

    <!-- Orbiting Ring -->
    <ImageView
        android:id="@+id/imgOrbit"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/ic_ai_orbit"
        app:layout_constraintBottom_toBottomOf="@id/cardIcon"
        app:layout_constraintEnd_toEndOf="@id/cardIcon"
        app:layout_constraintStart_toStartOf="@id/cardIcon"
        app:layout_constraintTop_toTopOf="@id/cardIcon" />

    <!-- Brain Icon Container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardIcon"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="80dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="80dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center"
            android:src="@drawable/img_27"
            />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="AI Analysis in Progress"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardIcon" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Please wait while we analyze patient data"
        android:textColor="@color/ai_processing_white_light"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <!-- Checklist -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:orientation="vertical"
        android:paddingHorizontal="40dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <!-- Item 1 -->
        <LinearLayout
            android:id="@+id/layoutStep1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="8dp">

            <ImageView
                android:id="@+id/imgStep1"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_completed_check" />

            <TextView
                android:id="@+id/tvStep1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Analyzing vital signs..."
                android:textColor="@color/white"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Item 2 -->
        <LinearLayout
            android:id="@+id/layoutStep2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="8dp">

            <ImageView
                android:id="@+id/imgStep2"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_completed_check" />

            <TextView
                android:id="@+id/tvStep2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Processing symptoms..."
                android:textColor="@color/white"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Item 3 -->
        <LinearLayout
            android:id="@+id/layoutStep3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="8dp">

            <ImageView
                android:id="@+id/imgStep3"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_completed_check" />

            <TextView
                android:id="@+id/tvStep3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Evaluating medical history..."
                android:textColor="@color/white"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Item 4 -->
        <LinearLayout
            android:id="@+id/layoutStep4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="8dp">

            <FrameLayout
                android:layout_width="24dp"
                android:layout_height="24dp">
                <ImageView
                    android:id="@+id/imgStep4"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_completed_check"
                    android:visibility="gone"/>
                <ProgressBar
                    android:id="@+id/pbStep4"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:indeterminateTint="@color/white" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvStep4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Calculating risk score..."
                android:textColor="@color/white"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Item 5 -->
        <LinearLayout
            android:id="@+id/layoutStep5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="8dp">

            <FrameLayout
                android:layout_width="24dp"
                android:layout_height="24dp">
                <ImageView
                    android:id="@+id/imgStep5"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_completed_check"
                    android:visibility="gone"/>
                <ProgressBar
                    android:id="@+id/pbStep5"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:indeterminateTint="@color/white"
                    android:visibility="gone"/>
                <ImageView
                    android:id="@+id/imgStep5Pending"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_pending_circle" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvStep5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:alpha="0.5"
                android:text="Generating recommendations..."
                android:textColor="@color/white"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Bottom Progress -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="40dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ProgressBar
            android:id="@+id/progressBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:progress="80"
            android:progressDrawable="@drawable/bg_ai_progress_bar" />

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="80%\nComplete"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:alpha="0.6"
            android:text="Using advanced machine learning algorithms"
            android:textColor="@color/white"
            android:textSize="12sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="4dp" />
            <solid android:color="#F3F4F6" /> <!-- Grey track -->
        </shape>
    </item>
    <item android:right="12dp"> <!-- Representing 95% -->
        <shape>
            <corners android:radius="4dp" />
            <solid android:color="#E02424" /> <!-- Red progress -->
        </shape>
    </item>
</layer-list>
